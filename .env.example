# Base URL under test. Defaults to https://www.ebay.com if unset.
BASE_URL=https://www.ebay.com

# eBay account credentials used by auth.setup.ts to create a persistent
# browser session. Cart tests (03, 04, 05) require these to be set so that
# cart.ebay.com does not trigger the hCaptcha bot-detection challenge.
# Leave unset to run only the non-cart tests.
EBAY_EMAIL=your.ebay@email.com
EBAY_PASSWORD=your_password

# Guest email used during the checkout flow (fake — no real account).
GUEST_EMAIL=testguest.automation@example.com

# Path to the JSON test-data file (relative to project root).
TEST_DATA_PATH=test-data/search.json
